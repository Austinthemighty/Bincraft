<div class="page-header">
  <h1>Locations</h1>
  <div class="page-actions">
    <a href="/locations/new" class="btn btn-primary">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true" focusable="false"><path d="M12 5v14M5 12h14"/></svg>
      New Location
    </a>
  </div>
</div>

<% if (!locations || locations.length === 0) { %>
  <div class="empty-state">
    <h3>No locations yet</h3>
    <p>Organize your storage in a facility → area → location hierarchy. You'll need at least one location before you can assign items to shelves or racks.</p>
    <a href="/locations/new" class="btn btn-primary">Add a location</a>
  </div>
<% } else { %>
  <%
    function renderTree(nodes) {
      if (!nodes || nodes.length === 0) return '';
      let html = '<ul class="location-tree">';
      nodes.forEach(node => {
        html += '<li>';
        html += '<div class="location-node">';
        html += `<span class="location-type">${node.type}</span> `;
        html += `<span class="location-name">${node.name}</span>`;
        if (node.description) html += ` <span class="location-desc">${node.description}</span>`;
        html += ` <a href="/locations/${node.id}/edit" class="btn btn-ghost btn-sm">Edit</a>`;
        html += ` <form method="POST" action="/locations/${node.id}?_method=DELETE" style="display:inline">`;
        html += `<button type="submit" class="btn btn-danger btn-sm" data-confirm="Are you sure you want to delete this location?">Delete</button>`;
        html += `</form>`;
        html += '</div>';
        if (node.children && node.children.length > 0) {
          html += renderTree(node.children);
        }
        html += '</li>';
      });
      html += '</ul>';
      return html;
    }
  %>
  <%- renderTree(locations) %>
<% } %>
