<aside class="sidebar" id="sidebar" aria-label="Main navigation">
  <div class="sidebar-brand">
    <div class="brand-icon" aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" focusable="false"><path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-7 3c1.93 0 3.5 1.57 3.5 3.5S13.93 13 12 13s-3.5-1.57-3.5-3.5S10.07 6 12 6zm7 13H5v-.23c0-.62.28-1.2.76-1.58C7.47 15.82 9.64 15 12 15s4.53.82 6.24 2.19c.48.38.76.97.76 1.58V19z"/></svg>
    </div>
    <span class="brand-text">Bincraft</span>
  </div>

  <nav class="sidebar-nav" aria-label="Sections">
    <div class="nav-section">
      <div class="nav-section-label" aria-hidden="true">Overview</div>
      <a href="/dashboard" class="nav-item <%= typeof activePage !== 'undefined' && activePage === 'dashboard' ? 'active' : '' %>"
         <%= typeof activePage !== 'undefined' && activePage === 'dashboard' ? 'aria-current="page"' : '' %>>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true" focusable="false"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
        <span class="nav-label">Dashboard</span>
      </a>
    </div>

    <div class="nav-section">
      <div class="nav-section-label" aria-hidden="true">Inventory</div>
      <a href="/items" class="nav-item <%= typeof activePage !== 'undefined' && activePage === 'items' ? 'active' : '' %>"
         <%= typeof activePage !== 'undefined' && activePage === 'items' ? 'aria-current="page"' : '' %>>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true" focusable="false"><path d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
        <span class="nav-label">Items</span>
      </a>
      <a href="/cards" class="nav-item <%= typeof activePage !== 'undefined' && activePage === 'cards' ? 'active' : '' %>"
         <%= typeof activePage !== 'undefined' && activePage === 'cards' ? 'aria-current="page"' : '' %>>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true" focusable="false"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M7 7h4v4H7zM13 7h4M13 11h4M7 15h10"/></svg>
        <span class="nav-label">Cards</span>
      </a>
      <a href="/scan" class="nav-item scan-action"
         <%= typeof activePage !== 'undefined' && activePage === 'scan' ? 'aria-current="page"' : '' %>>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true" focusable="false"><path d="M4 7V4h3M20 7V4h-3M4 17v3h3M20 17v3h-3"/><rect x="7" y="7" width="10" height="10" rx="1"/></svg>
        <span class="nav-label">Scan Card</span>
      </a>
    </div>

    <div class="nav-section">
      <div class="nav-section-label" aria-hidden="true">Orders</div>
      <a href="/orders" class="nav-item <%= typeof activePage !== 'undefined' && activePage === 'orders' ? 'active' : '' %>"
         <%= typeof activePage !== 'undefined' && activePage === 'orders' ? 'aria-current="page"' : '' %>>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true" focusable="false"><path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2"/><rect x="9" y="3" width="6" height="4" rx="1"/><path d="M9 12h6M9 16h6"/></svg>
        <span class="nav-label">Orders</span>
      </a>
      <a href="/receiving" class="nav-item <%= typeof activePage !== 'undefined' && activePage === 'receiving' ? 'active' : '' %>"
         <%= typeof activePage !== 'undefined' && activePage === 'receiving' ? 'aria-current="page"' : '' %>>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true" focusable="false"><path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/><path d="M3.27 6.96L12 12.01l8.73-5.05M12 22.08V12"/></svg>
        <span class="nav-label">Receiving</span>
      </a>
    </div>

    <div class="nav-section">
      <div class="nav-section-label" aria-hidden="true">Manage</div>
      <a href="/suppliers" class="nav-item <%= typeof activePage !== 'undefined' && activePage === 'suppliers' ? 'active' : '' %>"
         <%= typeof activePage !== 'undefined' && activePage === 'suppliers' ? 'aria-current="page"' : '' %>>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true" focusable="false"><path d="M3 21h18M3 7v1a3 3 0 006 0V7m0 0v1a3 3 0 006 0V7m0 0v1a3 3 0 006 0V7M3 7l1.5-4h15L21 7"/></svg>
        <span class="nav-label">Suppliers</span>
      </a>
      <a href="/locations" class="nav-item <%= typeof activePage !== 'undefined' && activePage === 'locations' ? 'active' : '' %>"
         <%= typeof activePage !== 'undefined' && activePage === 'locations' ? 'aria-current="page"' : '' %>>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true" focusable="false"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
        <span class="nav-label">Locations</span>
      </a>
      <a href="/settings" class="nav-item <%= typeof activePage !== 'undefined' && activePage === 'settings' ? 'active' : '' %>"
         <%= typeof activePage !== 'undefined' && activePage === 'settings' ? 'aria-current="page"' : '' %>>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true" focusable="false"><circle cx="12" cy="12" r="3"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
        <span class="nav-label">Settings</span>
      </a>
    </div>
  </nav>

  <% if (typeof currentUser !== 'undefined' && currentUser) { %>
  <div class="sidebar-footer">
    <button type="button" class="sidebar-user" onclick="logout()" aria-label="Sign out of <%= currentUser.name || 'your account' %>">
      <div class="user-avatar" aria-hidden="true"><%= currentUser.name ? currentUser.name.charAt(0).toUpperCase() : 'U' %></div>
      <div class="user-info">
        <div class="user-name"><%= currentUser.name || 'User' %></div>
      </div>
    </button>
  </div>
  <% } %>

  <button class="sidebar-toggle" id="sidebar-toggle-btn" aria-label="Toggle sidebar" aria-controls="sidebar">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true" focusable="false"><path d="M15 18l-6-6 6-6"/></svg>
  </button>
</aside>
