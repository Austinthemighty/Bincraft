<ul class="breadcrumbs">
  <li><a href="/items">Items</a></li>
  <li><%= item.name %></li>
</ul>

<div class="page-header">
  <h1><%= item.name %></h1>
  <div class="page-actions">
    <form method="POST" action="/items/<%= item.id %>/queue" class="inline-form">
      <button type="submit" class="btn btn-primary">Add to Order Queue</button>
    </form>
    <% if (item.supplier_url) { %>
    <a href="<%= item.supplier_url %>" class="btn btn-secondary" target="_blank" rel="noopener">Reorder &rarr;</a>
    <% } %>
    <a href="/items/<%= item.id %>/clone" class="btn btn-ghost">Clone</a>
    <a href="/items/<%= item.id %>/edit" class="btn btn-secondary">Edit</a>
    <form method="POST" action="/items/<%= item.id %>?_method=DELETE" class="inline-form">
      <button type="submit" class="btn btn-danger" data-confirm="Deactivate this item?">Deactivate</button>
    </form>
  </div>
</div>

<div class="detail-grid">
  <div class="panel">
    <div class="panel-header">Item Details</div>
    <dl>
      <dt>Part Number</dt>
      <dd><code><%= item.part_number %></code></dd>
      <dt>Description</dt>
      <dd><%= item.description || 'No description' %></dd>
      <dt>Supplier</dt>
      <dd><% if (item.supplier_name) { %><a href="/suppliers/<%= item.supplier_id %>"><%= item.supplier_name %></a><% } else { %>None<% } %></dd>
      <dt>Location</dt>
      <dd><%= item.location_name || 'Not assigned' %></dd>
      <dt>Unit of Measure</dt>
      <dd><%= item.unit_of_measure || 'N/A' %></dd>
      <dt>Cost per Unit</dt>
      <dd>$<%= parseFloat(item.cost_per_unit || 0).toFixed(6) %></dd>
      <% const packSize = item.pack_size || 1; %>
      <% if (packSize > 1) { %>
      <dt>Pack Size</dt>
      <dd><%= packSize %> units/pack &middot; $<%= (parseFloat(item.cost_per_unit || 0) * packSize).toFixed(2) %> per pack</dd>
      <% } %>
      <dt>Order By</dt>
      <dd><%= item.order_unit === 'pack' ? 'Pack' : 'Individual Unit' %></dd>
      <dt>Reorder Point</dt>
      <dd><%= item.reorder_point %></dd>
      <dt>Reorder Quantity</dt>
      <dd><%= item.reorder_quantity %></dd>
      <dt>Container Qty</dt>
      <dd><%= item.container_quantity || 'N/A' %></dd>
      <dt>Lead Time</dt>
      <dd><%= item.lead_time_days != null ? item.lead_time_days + ' days' : 'N/A' %></dd>
      <dt>Safety Factor</dt>
      <dd><%= item.safety_factor != null ? item.safety_factor : 'N/A' %></dd>
      <dt>Current Stock</dt>
      <dd>
        <% if (item.current_stock <= 0) { %>
          <span class="stock-out"><%= item.current_stock %></span>
        <% } else if (item.current_stock <= item.reorder_point) { %>
          <span class="stock-low"><%= item.current_stock %></span>
        <% } else { %>
          <span class="stock-ok"><%= item.current_stock %></span>
        <% } %>
      </dd>
      <% if (item.supplier_url) { %>
      <dt>Reorder URL</dt>
      <dd><a href="<%= item.supplier_url %>" target="_blank" rel="noopener"><%= item.supplier_url %></a></dd>
      <% } %>
    </dl>
  </div>

  <div class="panel">
    <div class="panel-header">Generate Cards</div>
    <form method="POST" action="/cards">
      <input type="hidden" name="item_id" value="<%= item.id %>">
      <div class="form-group">
        <label for="quantity">Number of Cards</label>
        <input type="number" id="quantity" name="quantity" value="1" min="1" max="100">
      </div>
      <div class="form-actions">
        <button type="submit" class="btn btn-primary">+ Generate Cards</button>
      </div>
    </form>
  </div>
</div>

<div class="section">
  <div class="section-header">
    <h2>Cards (<%= cards.length %>)</h2>
  </div>

  <% if (cards.length === 0) { %>
    <div class="empty-state">
      <p class="text-muted">No cards for this item yet. Use the form above to generate one.</p>
    </div>
  <% } else { %>
    <table class="data-table">
      <thead>
        <tr>
          <th>Card UID</th>
          <th>Loop #</th>
          <th>Status</th>
          <th>Location</th>
          <th>Last scanned</th>
        </tr>
      </thead>
      <tbody>
        <% cards.forEach(card => { %>
        <tr>
          <td data-label="Card UID"><a href="/cards/<%= card.id %>"><code><%= (card.card_uid || '').substring(0, 8) %>…</code></a></td>
          <td data-label="Loop"><%= card.loop_number || 1 %></td>
          <td data-label="Status"><span class="badge badge-<%= card.status %>"><%= (card.status || '').replace(/_/g, ' ') %></span></td>
          <td data-label="Location"><%= card.location_name || '—' %></td>
          <td data-label="Last scanned"><%= card.last_scanned_at ? new Date(card.last_scanned_at).toLocaleDateString() : '—' %></td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>
</div>

<div class="section">
  <div class="section-header">
    <h2>Recent Scan History</h2>
  </div>

  <% if (scanHistory.length === 0) { %>
    <div class="empty-state">
      <p class="text-muted">No scans yet. Scan activity will appear here once cards start moving.</p>
    </div>
  <% } else { %>
    <table class="data-table">
      <thead>
        <tr>
          <th>When</th>
          <th>Card</th>
          <th>Scanned by</th>
          <th>Action</th>
          <th>Status change</th>
        </tr>
      </thead>
      <tbody>
        <% scanHistory.forEach(scan => { %>
        <tr>
          <td data-label="When"><%= new Date(scan.scanned_at).toLocaleString() %></td>
          <td data-label="Card"><code><%= (scan.card_uid || '').substring(0, 8) %>…</code></td>
          <td data-label="Scanned by"><%= scan.scanned_by_name || 'Unknown' %></td>
          <td data-label="Action"><%= scan.action %></td>
          <td data-label="Status change">
            <% if (scan.previous_status && scan.new_status && scan.previous_status !== scan.new_status) { %>
              <span class="badge badge-<%= scan.previous_status %>"><%= scan.previous_status.replace(/_/g, ' ') %></span>
              <span aria-hidden="true" style="color:var(--text-tertiary);margin:0 var(--space-xs);">→</span>
              <span class="badge badge-<%= scan.new_status %>"><%= scan.new_status.replace(/_/g, ' ') %></span>
            <% } else if (scan.new_status) { %>
              <span class="badge badge-<%= scan.new_status %>"><%= scan.new_status.replace(/_/g, ' ') %></span>
            <% } else { %>
              —
            <% } %>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>
</div>
