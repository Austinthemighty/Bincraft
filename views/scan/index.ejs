<div class="scanner-container">
  <h1>Scan Card</h1>

  <div id="scanner-region" role="region" aria-label="Camera QR scanner"></div>

  <div id="scan-result" style="display:none;" aria-live="polite" aria-atomic="true"></div>

  <div class="manual-scan">
    <h3>Manual Entry</h3>
    <div class="form-group">
      <label for="manual-uid">Card UID or scan URL</label>
      <div class="form-row">
        <input type="text" id="manual-uid" name="manual-uid" placeholder="Paste or type a card UID..."
               autocomplete="off" autocapitalize="off" spellcheck="false" required>
        <button type="button" class="btn btn-primary" onclick="submitManualUid()">Submit scan</button>
      </div>
    </div>
  </div>
</div>

<script src="https://unpkg.com/html5-qrcode@2.3.8/html5-qrcode.min.js"></script>
<script src="/js/scanner.js"></script>
