<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title + ' - ' : '' %>ItemCards</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/print.css" media="print">
</head>
<body>
  <% if (typeof currentUser !== 'undefined' && currentUser) { %>
  <div class="app-shell">
    <%- include('partials/sidebar') %>
    <div class="main-content">
      <div class="mobile-header">
        <button class="btn-icon btn-ghost" id="mobile-menu-btn" style="width:40px;height:40px;flex-shrink:0;">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 12h18M3 6h18M3 18h18"/></svg>
        </button>
        <span style="font-family:var(--font-display);font-weight:800;font-size:var(--text-lg)">ItemCards</span>
      </div>
      <div class="page-container">
        <%- include('partials/flash') %>
        <%- body %>
      </div>
    </div>
  </div>
  <% } else { %>
  <%- body %>
  <% } %>

  <script src="https://unpkg.com/htmx.org@2.0.4"></script>
  <script src="/js/app.js"></script>
</body>
</html>
