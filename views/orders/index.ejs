<div class="page-header">
  <h1>Orders</h1>
  <div class="page-actions">
    <a href="/orders/queue" class="btn btn-primary">Order Queue</a>
  </div>
</div>

<% if (orders.length === 0) { %>
  <div class="empty-state">
    <h3>No orders yet</h3>
    <p>When a card is scanned (or added to the queue from the dashboard), its item shows up in the order queue — group them by supplier and create a purchase order from there.</p>
    <a href="/orders/queue" class="btn btn-primary">Open order queue</a>
  </div>
<% } else { %>
  <table class="data-table">
    <thead>
      <tr>
        <th>Order #</th>
        <th>Supplier</th>
        <th>Status</th>
        <th>Date</th>
        <th>Items</th>
        <th class="col-number">Total</th>
        <th class="col-actions">Actions</th>
      </tr>
    </thead>
    <tbody>
      <% orders.forEach(order => { %>
      <tr>
        <td data-label="Order #"><a href="/orders/<%= order.id %>"><%= order.order_number %></a></td>
        <td data-label="Supplier"><%= order.supplier_name %></td>
        <td data-label="Status"><span class="badge badge-<%= order.status %>"><%= order.status.replace(/_/g, ' ') %></span></td>
        <td data-label="Date"><%= new Date(order.created_at).toLocaleDateString() %></td>
        <td data-label="Items"><%= order.line_count %> line(s)</td>
        <td data-label="Total" class="col-number">$<%= parseFloat(order.total_cost || 0).toFixed(2) %></td>
        <td class="col-actions">
          <a href="/orders/<%= order.id %>" class="btn btn-ghost btn-sm">View</a>
          <% if (['submitted', 'confirmed', 'shipped'].includes(order.status)) { %>
            <a href="/receiving/<%= order.id %>" class="btn btn-ghost btn-sm">Receive</a>
          <% } %>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
<% } %>
