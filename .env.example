# Server ports
HTTP_PORT=80
HTTPS_PORT=443

# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/itemcards

# Auth
BETTER_AUTH_SECRET=change-me-to-a-random-32-character-string
BETTER_AUTH_URL=https://localhost

# SSL mode: 'auto' (self-signed), 'letsencrypt', 'custom', or 'off'
SSL_MODE=auto

# Custom certs (when SSL_MODE=custom)
SSL_CERT=
SSL_KEY=

# Let's Encrypt (when SSL_MODE=letsencrypt)
SSL_DOMAIN=
SSL_EMAIL=

# Cloudflare DNS challenge (optional, for Let's Encrypt without port 80)
SSL_CF_API_TOKEN=
SSL_CF_ZONE_ID=

# Email notifications (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@itemcards.local
